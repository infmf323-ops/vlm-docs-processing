APP_NAME=Invoice Extraction UI
API_V1_PREFIX=/api/v1
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=1440

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=invoice_ui
POSTGRES_USER=invoice_user
POSTGRES_PASSWORD=invoice_password

S3_ENDPOINT_URL=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=invoice-jobs

MODEL_PATH=E:/thesis/outputs/Bennet1996_donut-small_ft_best
MODEL_NAME=Bennet1996/donut-small
PADDLEOCR_VL_MODEL_NAME=PaddlePaddle/PaddleOCR-VL
# MRZ-путь для паспортов: каталог дообученного LoRA-адаптера (пусто = отключено)
PASSPORT_MRZ_ADAPTER_DIR=
MRZ_LOCALIZE=true
MRZ_POSTCORRECT=true
QWEN25_VL_MODEL_NAME=Qwen/Qwen2.5-VL-3B-Instruct
HUGGINGFACE_HOME=E:/thesis/.hf-cache
MAX_LENGTH=256
IMAGE_WIDTH=640
IMAGE_HEIGHT=480
DEVICE=auto
PROCESS_ONE_JOB_AT_A_TIME=true

# Создавать таблицы при старте API. В продакшене с Alembic выставьте false.
AUTO_CREATE_TABLES=true
# Максимальный размер загружаемого файла, МБ
MAX_UPLOAD_MB=20

FRONTEND_ORIGIN=http://localhost:5173
FRONTEND_ORIGIN_ALT=http://127.0.0.1:5173
